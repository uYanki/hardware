   5          void uart_init(void) {  // @baud=9600
   6   1          SCON = 0x50;        // 模式1:8位UART,波特率可变,启用接收 . SM0=0;SM1=1;REN=1;
   7   1          PCON |= 0x80;       // 设置波特率加倍, 波特率倍速位 SMOD=1, SMOD0=0
   8   1          ES = 1;             // 串口开关
   9   1          TMOD &= 0x0f;       // timer mode,清除原定时器工作模式
  10   1          TMOD |= 0x20;       // 设置为八位自动重载
  11   1          TH1 = TL1 = 0xFA;   // 赋定时器初值
  12   1          ET1       = 0;      // disenable timer1, 关闭定时器1的中断
  13   1          TR1       = 1;      // timer1 run, 启动定时器1
  14   1      }
  15          
  16          void uart_sendchar(char byte) {
  17   1          SBUF = byte;    //传入数据
  18   1          while (!TI) {}  //等待发送完毕
  19   1          TI = 0;         //将数据发送标志位复位
  20   1      }
  21          
  22          void uart_sendline(void) {  // 换行
  23   1          uart_sendchar('\r');
