  36          void uart_senddec(int number) reentrant {
  37   1          if (number > 9)
  38   1              uart_senddec(number / 10);
  39   1          uart_sendchar('0' + number % 10);
  40   1      }
  41          
  42          void uart_sendhex(int number) reentrant {
  43   1          char val;
  44   1          if (number > 15)
  45   1              uart_sendhex(number / 16);
  46   1          val = number % 16;
  47   1          if (val < 10)
